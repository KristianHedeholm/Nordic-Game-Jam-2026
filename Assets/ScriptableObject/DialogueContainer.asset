  m_Name: DialogueContainer
  m_EditorClassIdentifier: Assembly-CSharp::DialogueContainer
  _introSlides:
  - 'The King has dressed himself in the

    <b>finest outfit in all the land.</b>'
  - "He will give you <b>three riddles.</b>\nFor each one, guess: <margin-left=\"300\">\n\u2022
    <align=\"left\">The <b>garment</b>\n\u2022 <align=\"left\">The <b>colour</b>\n\u2022
    <align=\"left\">The <b>material</b>"
  - 'At the end, the truth will be revealed.


    Choose your words wisely.


    <b>Your
    head depends on it.</b>'
  _kingRevealAllCorrectReply: '"BEHOLD! Am I not the most magnificently dressed monarch
    you have ever seen?"'
  _kingRevealReply: '"Feast your eyes upon the FINEST outfit ever crafted by mortal
    hands!"'
  _narratorLine: \n<size=30><i>...says the King, obviously wearing <b>absolutely
    nothing.</b></i></size>
  _topScoreMessage: '<b>{0}/3</b> Correct!

    "Extraordinary! You truly understand
    fashion!"'
  _mediocreScoreMessage: '<b>{0}/3</b> Correct.

    "Hmm. Some potential, perhaps."'
  _noScoreMessage: '<b>{0}/3</b> correct...

    "...I expected more from you."'
  _topScoreValue: 3
  _finalQuestionAllCorrect: '"You have <b>magnificent</b> taste!"

    "Would you
    like to admire another one of my spectacular outfits?"'
  _finalQuestion: '"You clearly need more practice."

    "Would you like to try
    again and improve yourself?"'
  _flatterTextAllCorrect: '"Yes Your Majesty, it would be an honour!"'
  _flatterText: '"Yes Your Majesty, please give me another chance!"'
